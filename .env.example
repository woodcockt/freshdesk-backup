# Freshdesk API credentials
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key_here

# Freshdesk sync behavior
FRESHDESK_SYNC_START=2015-01-01T00:00:00Z
FRESHDESK_PER_PAGE=100

# Local Postgres archive database
POSTGRES_DB=freshdesk_archive
POSTGRES_USER=freshdesk_archive
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=55432
DATABASE_URL=postgresql://freshdesk_archive:change_me@localhost:55432/freshdesk_archive

# Local Typesense search index
TYPESENSE_API_KEY=change_me_generate_a_random_secret
TYPESENSE_URL=http://127.0.0.1:8108
TYPESENSE_COLLECTION=freshdesk_tickets
SEARCH_BACKEND=typesense

# Secret used for HMAC hashes of redacted identifiers.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PII_HASH_SECRET=change_me_generate_a_random_secret
